{
  "name": "project_management_system",
  "version": "1.0.0",
  "description": "Production-ready Trello-like project management system",
  "scripts": {
    "install-all": "npm install --prefix server && npm install --prefix client",
    "start-backend": "npm start --prefix server",
    "dev-backend": "npm run dev --prefix server",
    "dev-frontend": "npm run dev --prefix client",
    "dev": "concurrently \"npm run dev-backend\" \"npm run dev-frontend\"",
    "build-frontend": "npm run build --prefix client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
